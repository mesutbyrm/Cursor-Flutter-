# Veritabanı (PostgreSQL)
DATABASE_URL="postgresql://canlifal:canlifal@localhost:5432/canlifal?schema=public"

# JWT — üretimde güçlü rastgele değerler kullanın (en az 32 karakter önerilir)
JWT_ACCESS_SECRET="dev-access-secret-change-me-16"
JWT_REFRESH_SECRET="dev-refresh-secret-change-16"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

PORT=3000
NODE_ENV=development

# İsteğe bağlı: virgülle ayrılmış origin listesi (boş bırakılırsa tüm originlere izin)
# CORS_ORIGIN="https://canlifal.example.com,http://localhost:5173"

# OneSignal (sunucu push — REST API Key mobil uygulamaya KONMAZ)
ONESIGNAL_APP_ID="578518ed-7b16-46a9-a1e6-7692d3ba55d8"
ONESIGNAL_REST_API_KEY="os_v2_app_..."

# Firebase Admin (canlifal.com/canlifal-firebase-adminsdk.json → api/ altına kopyalayın)
# GOOGLE_APPLICATION_CREDENTIALS=./canlifal-firebase-adminsdk.json

# Google native giriş (Android/iOS OAuth client ID)
GOOGLE_CLIENT_ID=""

# YouTube Data API v3 — şarkı araması (GET /api/music/search)
# Google Cloud Console → APIs & Services → YouTube Data API v3 etkin + API key
# Üretimde repoya yazmayın; sunucu .env veya gizli değişken olarak ekleyin.
# YOUTUBE_API_KEY=""

# Tencent TRTC — sesli oda + canlı yayın (POST /api/trtc/usersig)
# TRTC_SDK_APP_ID="1400000000"
# TRTC_SECRET_KEY=""

# TikTok Login Kit (yalnızca mobil)
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""

# LiveKit — sesli sohbet (yoksa uygulama TRTC kullanır)
# LIVEKIT_URL="wss://your-project.livekit.cloud"
# LIVEKIT_API_KEY=""
# LIVEKIT_API_SECRET=""

# Cloudflare R2 — kısa videolar (MP4 + thumbnail). Boşsa yerel uploads/shorts kullanılır.
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET_NAME="canlifal-shorts"
# R2_PUBLIC_URL="https://cdn.canlifal.com"
