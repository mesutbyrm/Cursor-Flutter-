# Sunucu
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# MySQL — web sitesi ile aynı veritabanını kullanın
DATABASE_URL="mysql://canlifal:secret@localhost:3306/canlifal"

# JWT
JWT_ACCESS_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_REFRESH_SECRET=change-me-another-long-random-string-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS (virgülle ayırın)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
