generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Paylaşılan veritabanı: web ve Flutter aynı Prisma şeması / tabloları kullanır.
model User {
  id              String         @id @default(cuid())
  email           String         @unique
  passwordHash    String
  displayName     String?
  username        String?        @unique
  phone           String?
  birthDate       DateTime?
  birthTime       String?
  language        String         @default("tr")
  googleId        String?        @unique
  tiktokId        String?        @unique
  bio             String?
  avatarUrl       String?
  coverUrl        String?
  coins           Int            @default(500)
  cfcBalance      Int            @default(0)
  membership      String         @default("basic")
  membershipExpiresAt DateTime?
  role            String         @default("user")
  followerCount   Int            @default(0)
  followingCount  Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  refreshTokens   RefreshToken[]
  followers       Follow[]       @relation("UserFollowers")
  following       Follow[]       @relation("UserFollowing")
  socialPosts         SocialPost[]
  cfcPaymentRequests  CfcPaymentRequest[]
  conversationsA      Conversation[] @relation("ConversationUserA")
  conversationsB      Conversation[] @relation("ConversationUserB")
  fortunes              UserFortune[]
  favorites             UserFavorite[]
  shortVideos           ShortVideo[]
  shortVideoComments    ShortVideoComment[]
}

/// Mobil / web fal geçmişi kaydı.
model UserFortune {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String
  slug        String?
  question    String?
  answer      String?
  summary     String?
  detail      String?
  luckyNumber Int?
  luckyColor  String?
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
}

/// Kullanıcı favorileri (profil, gönderi, fal, içerik linki).
model UserFavorite {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetType String
  targetId   String
  title      String?
  url        String?
  imageUrl   String?
  createdAt  DateTime @default(now())

  @@unique([userId, targetType, targetId])
  @@index([userId, createdAt])
}

model SocialPost {
  id             String   @id @default(cuid())
  authorId       String
  author         User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  caption        String?
  mediaUrl       String?
  postType       String   @default("text")
  fortuneType    String?
  isAutoShare    Boolean  @default(false)
  fortuneCount   Int      @default(0)
  viewCount      Int      @default(0)
  likesCount     Int      @default(0)
  commentsCount  Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  likes          SocialPostLike[]
  comments       SocialPostComment[]

  @@index([authorId])
  @@index([createdAt])
  @@index([postType, createdAt])
}

model SocialPostLike {
  id        String     @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime   @default(now())
  post      SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

model SocialPostComment {
  id        String     @id @default(cuid())
  postId    String
  authorId  String
  content   String
  createdAt DateTime   @default(now())
  post      SocialPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@index([authorId])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
}

model RefreshToken {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([userId])
}

/// Hediye kataloğu — platform (mobile/web/all) ve rarity ile filtrelenir.
model Gift {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  icon          String
  animation     String?
  animationType String   @default("lottie")
  price         Int
  rarity        String   @default("common")
  platform      String   @default("all")
  sound         String?
  sortOrder     Int      @default(0)
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  events        GiftEvent[]

  @@index([platform, enabled, sortOrder])
  @@index([rarity])
}

/// Canlı yayın / oda hediye işlemleri.
model GiftEvent {
  id           String   @id @default(cuid())
  giftId       String
  gift         Gift     @relation(fields: [giftId], references: [id], onDelete: Restrict)
  senderId     String?
  senderName   String
  receiverId   String?
  receiverName String
  streamId     String?
  roomId       String?
  quantity     Int      @default(1)
  coinCost     Int
  combo        Int      @default(1)
  platform     String   @default("mobile")
  createdAt    DateTime @default(now())

  @@index([streamId, createdAt])
  @@index([roomId, createdAt])
  @@index([senderId, createdAt])
  @@index([receiverId, createdAt])
}

/// CFC ödeme ayarları (admin paneli).
model CfcSettings {
  id                   String   @id @default("default")
  cfcWhatsappNumber    String   @default("")
  cfcPaparaAddress     String   @default("")
  cfcBankName          String?
  cfcBankIban          String   @default("")
  cfcBankAccountHolder String?
  cfcTlRate            Float    @default(1)
  cfcMinAmount         Int      @default(10)
  updatedAt            DateTime @updatedAt
}

/// CFC veya jeton yükleme talebi.
model CfcPaymentRequest {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  requestType   String   @default("cfc")
  amount        Int
  method        String
  packageId     String?
  packageTitle  String?
  coins         Int?
  priceTry      Float?
  senderInfo    String?
  notes         String?
  status        String   @default("pending")
  reviewedBy    String?
  reviewNote    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId, status])
  @@index([status, createdAt])
  @@index([requestType, status])
}

/// FCM push token (mobil).
model DevicePushToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String   @default("unknown")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

/// İki kullanıcı arası DM sohbeti.
model Conversation {
  id          String   @id @default(cuid())
  userAId     String
  userBId     String
  lastMessage String?
  unreadForA  Int      @default(0)
  unreadForB  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userA       User     @relation("ConversationUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB       User     @relation("ConversationUserB", fields: [userBId], references: [id], onDelete: Cascade)
  messages    DirectMessage[]

  @@unique([userAId, userBId])
  @@index([updatedAt])
}

model DirectMessage {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  text           String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

/// Uygulama / site bildirimleri.
model AppNotification {
  id         String   @id @default(cuid())
  userId     String?
  title      String
  body       String?
  type       String   @default("system")
  data       String?
  targetPath String?
  targetId   String?
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([userId, read, createdAt])
  @@index([createdAt])
}

/// PK (Battle) oturumu — sesli oda veya canlı yayın.
model PKBattle {
  id                  String          @id @default(cuid())
  battleType          String
  voiceRoomId         String?
  opponentVoiceRoomId String?
  liveStreamId        String?
  opponentLiveStreamId String?
  challengerId        String
  opponentId          String?
  status              String          @default("pending")
  startTime           DateTime?
  endTime             DateTime?
  winnerId            String?
  challengerScore     Int             @default(0)
  opponentScore       Int             @default(0)
  durationSeconds     Int             @default(300)
  targetScore         Int             @default(150000)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  participants        PKParticipant[]
  gifts               PKGift[]
  result              PKResult?

  @@index([battleType, status])
  @@index([voiceRoomId, status])
  @@index([opponentVoiceRoomId, status])
  @@index([liveStreamId, status])
  @@index([opponentLiveStreamId, status])
  @@index([challengerId, createdAt])
  @@index([opponentId, createdAt])
}

/// PK katılımcısı (challenger / opponent tarafı).
model PKParticipant {
  id          String   @id @default(cuid())
  battleId    String
  battle      PKBattle @relation(fields: [battleId], references: [id], onDelete: Cascade)
  userId      String
  side        String
  roomId      String?
  streamId    String?
  score       Int      @default(0)
  winStreak   Int      @default(0)
  displayName String?
  avatarUrl   String?
  createdAt   DateTime @default(now())

  @@unique([battleId, side])
  @@index([userId])
  @@index([roomId])
  @@index([streamId])
}

/// PK sırasında gönderilen hediye → puan kaydı.
model PKGift {
  id          String   @id @default(cuid())
  battleId    String
  battle      PKBattle @relation(fields: [battleId], references: [id], onDelete: Cascade)
  giftEventId String?
  senderId    String?
  senderName  String
  side        String
  giftSlug    String
  giftName    String?
  quantity    Int      @default(1)
  points      Int
  createdAt   DateTime @default(now())

  @@index([battleId, createdAt])
  @@index([senderId, createdAt])
}

/// PK sonucu — geçmiş ve şampiyon rozeti.
model PKResult {
  id                   String   @id @default(cuid())
  battleId             String   @unique
  battle               PKBattle @relation(fields: [battleId], references: [id], onDelete: Cascade)
  winnerId             String?
  winnerSide           String?
  challengerFinalScore Int
  opponentFinalScore   Int
  championBadge        Boolean  @default(true)
  createdAt            DateTime @default(now())

  @@index([winnerId, createdAt])
}

/// TikTok tarzı kısa videolar — dosyalar Cloudflare R2/CDN; burada yalnızca metadata.
model ShortVideo {
  id            String              @id @default(cuid())
  userId        String
  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoUrl      String
  thumbnailUrl  String?
  description   String?
  durationSec   Float?
  viewsCount    Int                 @default(0)
  likesCount    Int                 @default(0)
  commentsCount Int                 @default(0)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  likes         ShortVideoLike[]
  comments      ShortVideoComment[]
  views         ShortVideoView[]

  @@index([userId, createdAt])
  @@index([createdAt])
  @@map("short_videos")
}

model ShortVideoLike {
  id        String     @id @default(cuid())
  videoId   String
  userId    String
  video     ShortVideo @relation(fields: [videoId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())

  @@unique([videoId, userId])
  @@index([videoId])
  @@index([userId])
}

model ShortVideoComment {
  id        String     @id @default(cuid())
  videoId   String
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String
  video     ShortVideo @relation(fields: [videoId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())

  @@index([videoId, createdAt])
  @@index([userId])
}

/// Kullanıcı başına tek izlenme sayımı (≥3 sn).
model ShortVideoView {
  id        String     @id @default(cuid())
  videoId   String
  userId    String
  video     ShortVideo @relation(fields: [videoId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())

  @@unique([videoId, userId])
  @@index([videoId])
}
