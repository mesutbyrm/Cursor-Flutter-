generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Paylaşılan veritabanı: web ve Flutter aynı Prisma şeması / tabloları kullanır.
model User {
  id              String         @id @default(cuid())
  email           String         @unique
  passwordHash    String
  displayName     String?
  username        String?        @unique
  bio             String?
  avatarUrl       String?
  coverUrl        String?
  coins           Int            @default(500)
  cfcBalance      Int            @default(0)
  role            String         @default("user")
  followerCount   Int            @default(0)
  followingCount  Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  refreshTokens   RefreshToken[]
  followers       Follow[]       @relation("UserFollowers")
  following       Follow[]       @relation("UserFollowing")
  socialPosts     SocialPost[]
}

model SocialPost {
  id             String   @id @default(cuid())
  authorId       String
  author         User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  caption        String?
  mediaUrl       String?
  postType       String   @default("text")
  likesCount     Int      @default(0)
  commentsCount  Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([authorId])
  @@index([createdAt])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
}

model RefreshToken {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([userId])
}

/// Hediye kataloğu — platform (mobile/web/all) ve rarity ile filtrelenir.
model Gift {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  icon          String
  animation     String?
  animationType String   @default("lottie")
  price         Int
  rarity        String   @default("common")
  platform      String   @default("all")
  sound         String?
  sortOrder     Int      @default(0)
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  events        GiftEvent[]

  @@index([platform, enabled, sortOrder])
  @@index([rarity])
}

/// Canlı yayın / oda hediye işlemleri.
model GiftEvent {
  id           String   @id @default(cuid())
  giftId       String
  gift         Gift     @relation(fields: [giftId], references: [id], onDelete: Restrict)
  senderId     String?
  senderName   String
  receiverId   String?
  receiverName String
  streamId     String?
  roomId       String?
  quantity     Int      @default(1)
  coinCost     Int
  combo        Int      @default(1)
  platform     String   @default("mobile")
  createdAt    DateTime @default(now())

  @@index([streamId, createdAt])
  @@index([roomId, createdAt])
  @@index([senderId, createdAt])
  @@index([receiverId, createdAt])
}

/// Ödeme yöntemi bilgileri (WhatsApp, Papara, havale).
model PaymentConfig {
  id              String   @id @default("default")
  whatsappNumber  String   @default("")
  paparaAddress   String   @default("")
  bankIban        String   @default("")
  bankName        String?
  accountHolder   String?
  updatedAt       DateTime @updatedAt
}

/// Kullanıcı ödeme bildirimi / talebi.
model PaymentRequest {
  id            String   @id @default(cuid())
  userId        String?
  userName      String
  method        String
  packageId     String?
  packageTitle  String?
  amountTry     Float?
  coins         Int      @default(0)
  status        String   @default("pending")
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status, createdAt])
  @@index([userId])
}

/// Uygulama / site bildirimleri.
model AppNotification {
  id         String   @id @default(cuid())
  userId     String?
  title      String
  body       String?
  type       String   @default("system")
  targetPath String?
  targetId   String?
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([userId, read, createdAt])
  @@index([createdAt])
}
